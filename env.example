# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── App mode ──────────────────────────────────────────────────────────────────
# true  → rule-based AI, no API key needed (perfect for hackathon demo)
# false → uses real OpenAI API
DEMO_MODE=true

# ── FastAPI backend ────────────────────────────────────────────────────────────
API_HOST=http://localhost:8000
API_PORT=8000

# ── OpenAI (only needed when DEMO_MODE=false) ─────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key...
OPENAI_MODEL=gpt-4o-mini

# ── Google Sheets ─────────────────────────────────────────────────────────────
# 1. Create a Google Sheet
# 2. Share it with your service account email (Editor access)
# 3. Paste the Sheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_SHEET_TAB=leads
# Path to the downloaded JSON key file from Google Cloud service account
GOOGLE_SERVICE_ACCOUNT=service_account.json

# ── WhatsApp via CallMeBot (free) ─────────────────────────────────────────────
# Register: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=+91XXXXXXXXXX
WHATSAPP_API_KEY=your-callmebot-api-key
